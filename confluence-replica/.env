# Docker Compose runtime env for local Postgres + pgvector
POSTGRES_DB=confluence_replica
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PG_PORT=5432

# Host bind mount directory for PostgreSQL data
# Expected location: ~/.local/viki/confluence/postgres-data
PG_DATA_DIR=/Users/nkharche/.local/viki/confluence/postgres-data

# Optional overrides for Ollama runtime bootstrap
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
